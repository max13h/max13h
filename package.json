{
  "name": "max13h",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:blog": "pnpm --filter blog dev",
    "dev:portfolio": "pnpm --filter portfolio dev",
    "build": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter './apps/*' lint",
    "lint:root": "eslint packages/",
    "format": "pnpm --filter './apps/*' format",
    "format:root": "prettier --write packages/ *.json *.yaml *.mjs",
    "pre-commit": "pnpm format:root && pnpm lint:root",
    "prepare": "husky"
  },
  "devDependencies": {
    "@max13h/tooling": "workspace:*",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1"
  }
}
