---
import { Icon } from "astro-icon/components"
import UIDarkModeBtn from "./UIDarkModeBtn.astro"
import UILangSwitchBtn from "./UILangSwitchBtn.astro"
import { getLocaleFromUrl } from "@max13h/i18n"
import faviconUrl from "../assets/favicon.svg"

interface Props {
  switchPath?: string
  siteLabel?: string
  siteHref?: string
}

type IconElement = {
  link: string
  name: string
  title: string
}

const { switchPath, siteLabel, siteHref } = Astro.props

const locale = getLocaleFromUrl(Astro.url)
const labelsByLocale = {
  en: {
    homeAlt: "Link to home page",
    github: "Link to my GitHub profile",
    linkedin: "Link to my LinkedIn profile",
  },
  fr: {
    homeAlt: "Lien vers la page d'accueil",
    github: "Lien vers mon profil GitHub",
    linkedin: "Lien vers mon profil LinkedIn",
  },
} as const
const labels = labelsByLocale[locale] ?? labelsByLocale.fr

const icons: IconElement[] = [
  {
    link: "https://github.com/max13h/",
    name: "github",
    title: labels.github,
  },
  {
    link: "https://www.linkedin.com/in/hmae/",
    name: "linkedin",
    title: labels.linkedin,
  },
]

const homeLabel = siteLabel ?? "blog.hmae.fr"
const homeHref = siteHref ?? `/${locale}/`
---

<nav>
  <a href={homeHref} class="home">
    <img src={faviconUrl.src} alt={labels.homeAlt} />
    <span>{homeLabel}</span>
  </a>

  <div class="links">
    <div class="social-media">
      {
        icons.map((icon) => (
          <a href={icon.link} target="_blank">
            <Icon name={icon.name} title={icon.title} />
          </a>
        ))
      }
    </div>
    <span aria-hidden="true">|</span>
    <div class="settings">
      <UILangSwitchBtn switchPath={switchPath} />
      <UIDarkModeBtn />
    </div>
  </div>
</nav>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    padding: 1rem;
    position: sticky;
    width: 100%;
    top: 0;

    & .home {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      position: relative;
      color: inherit;
      text-decoration: none;

      & img {
        width: 1.5rem;
      }
    }

    & .links {
      display: flex;
      align-items: center;
      gap: 1rem;

      & .social-media,
      .settings {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      & a {
        font-size: 1.5rem;
        color: inherit;

        &:visited {
          color: inherit;
        }
      }
    }
  }

  @media (max-width: 1280px) {
    nav {
      backdrop-filter: blur(1rem);
      & .home span {
        display: none;
      }
    }
  }
</style>
